---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-100 bg-white">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-5">
      <div class="col-span-2 lg:col-span-2">
        <a href="/" class="text-xl font-bold tracking-tight text-gray-900">ToolVader</a>
        <p class="mt-4 max-w-xs text-sm text-gray-500">
          Simple business tools for freelancers. Follow <a href="https://instagram.com/umamcodes" target="_blank" rel="noopener noreferrer" class="font-semibold text-gray-900 hover:underline">@umamcodes</a> for updates and new tools.
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900">Resources</h3>
        <ul role="list" class="mt-4 space-y-4">
          <li>
            <a href="/tools/freelance-rate-calculator" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Calculator</a>
          </li>
          <li>
            <a href="/about" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">About</a>
          </li>
          <li>
            <a href="/contact" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Contact</a>
          </li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900">Legal</h3>
        <ul role="list" class="mt-4 space-y-4">
          <li>
            <a href="/privacy-policy" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Privacy Policy</a>
          </li>
          <li>
            <a href="/terms-of-service" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Terms of Service</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-12 border-t border-gray-100 pt-8">
      <p class="text-sm text-gray-400">
        &copy; {currentYear} ToolVader. All rights reserved.
      </p>
    </div>
  </div>
</footer>
