---
import { guides } from '../data/guides';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// Find the active guide
const currentGuide = guides.find(guide => guide.path === currentPath);

// Filter out the current guide
const otherGuides = guides.filter(guide => guide.path !== currentPath);

// Prioritize guides in same category, followed by other categories
let relatedGuides = [];
if (currentGuide) {
  const sameCategory = otherGuides.filter(guide => guide.category === currentGuide.category);
  const differentCategory = otherGuides.filter(guide => guide.category !== currentGuide.category);
  relatedGuides = [...sameCategory, ...differentCategory].slice(0, 3);
} else {
  relatedGuides = otherGuides.slice(0, 3);
}
---

<div class="mt-24 border-t border-gray-100 pt-16">
  <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Related Guides & Resources</h2>
  <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-3">
    {relatedGuides.map((guide) => (
      <div class="flex flex-col rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-gray-300">
        <div class="flex-1">
          <span class="inline-flex items-center rounded-md bg-purple-50 px-2 py-1 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10 mb-4">
            {guide.category} Strategy
          </span>
          <h3 class="text-base font-semibold leading-7 text-gray-900">{guide.title}</h3>
          <p class="mt-3 text-sm leading-6 text-gray-600 line-clamp-3">
            {guide.description}
          </p>
        </div>
        <div class="mt-6 pt-5 border-t border-gray-50">
          <a href={guide.path} class="inline-flex items-center text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors">
            Read Guide <span aria-hidden="true" class="ml-1">→</span>
          </a>
        </div>
      </div>
    ))}
  </div>
</div>
