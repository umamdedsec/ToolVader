---
import { tools } from '../data/tools';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// Find the current active tool
const currentTool = tools.find(tool => tool.href === currentPath);

// Filter out the current tool so we don't link to the active page
const otherTools = tools.filter(tool => tool.href !== currentPath);

// Prioritize tools in the same category, followed by other categories
let relatedTools = [];
if (currentTool) {
  const sameCategory = otherTools.filter(tool => tool.category === currentTool.category);
  const differentCategory = otherTools.filter(tool => tool.category !== currentTool.category);
  relatedTools = [...sameCategory, ...differentCategory].slice(0, 3);
} else {
  // Fallback if current path is not mapped
  relatedTools = otherTools.slice(0, 3);
}
---

<div class="mt-24 border-t border-gray-100 pt-16">
  <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Related Business Tools</h2>
  <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-3">
    {relatedTools.map((tool) => (
      <div class="flex flex-col rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-gray-300">
        <div class="flex-1">
          <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10 mb-4">
            {tool.category}
          </span>
          <h3 class="text-base font-semibold leading-7 text-gray-900">{tool.title}</h3>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            {tool.description}
          </p>
        </div>
        <div class="mt-6 pt-5 border-t border-gray-50">
          <a href={tool.href} class="inline-flex items-center text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors">
            Try Tool <span aria-hidden="true" class="ml-1">→</span>
          </a>
        </div>
      </div>
    ))}
  </div>
</div>
