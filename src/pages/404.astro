---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tools } from '../data/tools';

const pageTitle = "Page Not Found - ToolVader";
const pageDescription = "The page you are looking for could not be found. Explore ToolVader's free business calculators instead.";

// Get the 3 featured calculators in the priority order requested
const recoveryTitles = [
  "Freelance Rate Calculator",
  "Project Price Calculator",
  "Profit Margin Calculator"
];

const recoveryCalculators = recoveryTitles
  .map(title => tools.find(tool => tool.title === title))
  .filter((tool): tool is typeof tools[number] => !!tool);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription
};
---

<BaseLayout 
  title={pageTitle} 
  description={pageDescription}
  structuredData={structuredData}
>
  <div class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <p class="text-base font-semibold text-purple-600">404 Error</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">Page Not Found</h1>
      <p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
        The page you're looking for may have been moved, deleted, or never existed.
      </p>

      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a 
          href="/" 
          class="rounded-md bg-gray-900 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900 transition-colors"
        >
          Back to Homepage
        </a>
        <a 
          href="/tools" 
          class="text-sm font-semibold leading-6 text-gray-900 hover:text-gray-600 transition-colors"
        >
          Browse All Tools <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Recovery Section -->
  <div class="bg-gray-50/50 py-16 sm:py-20 border-t border-gray-100">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-12">
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
          Try One of Our Free Calculators
        </h2>
        <p class="mt-4 text-base text-gray-600">
          Get back on track with our most popular financial tools for freelancers and independent professionals.
        </p>
      </div>

      <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        {recoveryCalculators.map((tool) => (
          <div class="flex flex-col rounded-2xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-gray-300">
            <div class="flex-1">
              <div class="flex items-center gap-x-3 mb-6">
                <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                  {tool.category}
                </span>
                <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10">
                  Updated for 2026
                </span>
              </div>
              <h3 class="text-lg font-semibold leading-8 tracking-tight text-gray-900">{tool.title}</h3>
              <p class="mt-4 text-base leading-7 text-gray-600">
                {tool.description}
              </p>
            </div>
            <div class="mt-8 pt-6 border-t border-gray-100">
              <a href={tool.href} class="inline-flex items-center text-sm font-semibold leading-6 text-gray-900 hover:text-gray-600 transition-colors">
                Launch Calculator <span aria-hidden="true" class="ml-2">→</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
