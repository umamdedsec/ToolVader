---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "About ToolVader: Helping Independent Professionals Thrive";
const description = "Discover how ToolVader builds simple, data-driven business tools for the modern independent professional. Empowering freelancers and consultants.";
---

<BaseLayout title={title} description={description}>
  <div class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">About ToolVader</h1>
        <p class="mt-6 text-lg leading-8 text-gray-600">
          We build simple, precise, and professional tools designed specifically for the modern independent professional.
        </p>
      </div>
      
      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900">Our Mission</h2>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            Being a freelancer is hard enough without having to worry about complex business calculations. ToolVader was born out of a desire to simplify the "business side" of freelancing. 
          </p>
          <p class="mt-4 text-lg leading-8 text-gray-600">
            Whether you're deciding what to charge a new client or projecting your monthly revenue, our tools provide data-driven insights to help you make confident decisions.
          </p>
        </div>
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900">Why ToolVader?</h2>
          <dl class="mt-10 space-y-8 text-base leading-7 text-gray-600">
            <div class="relative pl-9">
              <dt class="inline font-semibold text-gray-900">
                <svg class="absolute left-1 top-1 h-5 w-5 text-gray-900" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4.13-5.682z" clip-rule="evenodd" />
                </svg>
                Built for Freelancers.
              </dt>
              <dd class="inline">No generic business tools here. Every calculator is built with the freelance workflow in mind.</dd>
            </div>
            <div class="relative pl-9">
              <dt class="inline font-semibold text-gray-900">
                <svg class="absolute left-1 top-1 h-5 w-5 text-gray-900" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4.13-5.682z" clip-rule="evenodd" />
                </svg>
                Data-Driven.
              </dt>
              <dd class="inline">Our formulas use real-world market multipliers and profession-specific data.</dd>
            </div>
            <div class="relative pl-9">
              <dt class="inline font-semibold text-gray-900">
                <svg class="absolute left-1 top-1 h-5 w-5 text-gray-900" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4.13-5.682z" clip-rule="evenodd" />
                </svg>
                Always Free.
              </dt>
              <dd class="inline">We believe essential business tools should be accessible to everyone starting their independent journey.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
