---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Contact Us - ToolVader";
const description = "Have questions, feedback, or business inquiries? Reach out to the ToolVader team.";

const contactSections = [
  {
    title: "General Questions",
    description: "Curious about our tools or how we calculate our data? We're here to help.",
    email: "umam.dedsec@gmail.com",
    subject: "General Question",
    label: "Email Support"
  },
  {
    title: "Business Inquiries",
    description: "Interested in partnerships, sponsorships, or custom tool development?",
    email: "umam.dedsec@gmail.com",
    subject: "Business Inquiry",
    label: "Contact Partnerships"
  },
  {
    title: "Bug Reports",
    description: "Found an error or a calculation that doesn't seem right? Let us know.",
    email: "umam.dedsec@gmail.com",
    subject: "Bug Report",
    label: "Report a Bug"
  },
  {
    title: "Feature Requests",
    description: "Have an idea for a new freelance tool or a feature for the rate calculator?",
    email: "umam.dedsec@gmail.com",
    subject: "Feature Request",
    label: "Suggest Feature"
  }
];
---

<BaseLayout title={title} description={description}>
  <div class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <!-- Introduction -->
      <div class="mx-auto max-w-2xl lg:text-center">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">Get in Touch</h1>
        <p class="mt-6 text-lg leading-8 text-gray-600">
          We're constantly working to improve ToolVader. Whether you have a question about our calculators or want to discuss a potential partnership, we'd love to hear from you.
        </p>
        <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-gray-50 px-4 py-1.5 text-sm font-medium text-gray-600 ring-1 ring-inset ring-gray-200">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          Typically respond within 48 hours
        </div>
      </div>
      
      <!-- Contact Cards Grid -->
      <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none">
        <div class="grid grid-cols-1 gap-x-8 gap-y-8 lg:grid-cols-2">
          {contactSections.map((section) => (
            <div class="flex flex-col rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all hover:border-gray-200 hover:shadow-md">
              <div class="flex-1">
                <h3 class="text-lg font-bold leading-8 tracking-tight text-gray-900">{section.title}</h3>
                <p class="mt-4 text-base leading-7 text-gray-600">
                  {section.description}
                </p>
              </div>
              <div class="mt-8 pt-6 border-t border-gray-50">
                <a 
                  href={`mailto:${section.email}?subject=${encodeURIComponent(section.subject)}`} 
                  class="text-sm font-semibold leading-6 text-gray-900 hover:text-gray-600 transition-colors inline-flex items-center gap-2"
                >
                  {section.label} <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Social Support -->
      <div class="mx-auto mt-24 max-w-2xl text-center">
        <h2 class="text-2xl font-bold tracking-tight text-gray-900">Follow For Updates</h2>
        <p class="mt-4 text-base leading-7 text-gray-600">
          Follow <span class="font-semibold text-gray-900">@umamcodes</span> for ToolVader updates, new tools, and development progress.
        </p>
        <div class="mt-8 flex justify-center">
          <a href="https://instagram.com/umamcodes" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-gray-900 px-6 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 transition-all active:scale-95">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4s1.791-4 4-4 4 1.791 4 4-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
            </svg>
            Instagram (@umamcodes)
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
