---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { guides } from '../../data/guides';

const categories = [...new Set(guides.map(guide => guide.category))];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Freelance Guides & Resources - ToolVader",
  "description": "Browse free, high-quality freelance guides, pricing resources, and financial strategies on ToolVader to grow your business in 2026.",
  "url": "https://toolvader.com/guides"
};
---

<BaseLayout 
  title="Freelance Guides & Resources - ToolVader"
  description="Browse free, high-quality freelance guides, pricing resources, and financial strategies on ToolVader to grow your business in 2026."
  structuredData={structuredData}
>
  <!-- Hero Section -->
  <div class="bg-white px-6 py-16 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">Freelance Guides & Resources</h1>
      <p class="mt-6 text-lg leading-8 text-gray-600">
        In-depth strategies, pricing frameworks, and financial planning tips to help freelancers and solopreneurs build sustainable businesses in 2026. Access targeted resources in our <a href="/pricing-tools" class="font-semibold text-gray-900 hover:underline">Pricing Tools Hub</a>, <a href="/finance-tools" class="font-semibold text-gray-900 hover:underline">Finance Tools Hub</a>, and <a href="/income-tools" class="font-semibold text-gray-900 hover:underline">Income Tools Hub</a>.
      </p>
    </div>
  </div>

  <!-- Search and Filter Controls -->
  <div class="mx-auto max-w-7xl px-6 lg:px-8 pb-12">
    <div class="mx-auto max-w-xl mb-6">
      <label for="guide-search" class="sr-only">Search guides</label>
      <input 
        type="text" 
        id="guide-search" 
        placeholder="Search guides (e.g. rate, taxes, pricing)..." 
        class="block w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900 sm:text-sm transition-all"
      />
    </div>

    <div class="flex flex-wrap justify-center gap-2" id="category-filters">
      <button data-category="all" class="category-btn px-4 py-1.5 text-xs font-semibold rounded-full border border-gray-900 bg-gray-900 text-white transition-all shadow-sm">All</button>
      {categories.map((category) => (
        <button 
          data-category={category.toLowerCase()} 
          class="category-btn px-4 py-1.5 text-xs font-semibold rounded-full border border-gray-200 bg-white text-gray-700 hover:border-gray-300 transition-all"
        >
          {category}
        </button>
      ))}
    </div>
  </div>

  <!-- Guides Grid Section -->
  <div class="bg-gray-50/50 py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        <!-- Fallback No-results messaging -->
        <div id="no-results-msg" class="hidden text-center py-12 col-span-full">
          <p class="text-lg font-medium text-gray-500">No guides found. Try a different search.</p>
        </div>

        {guides.map((guide) => (
          <div 
            class="guide-card flex flex-col rounded-2xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-gray-300"
            data-title={guide.title.toLowerCase()}
            data-description={guide.description.toLowerCase()}
            data-category={guide.category.toLowerCase()}
          >
            <div class="flex-1">
              <div class="flex items-center gap-x-3 mb-6">
                <span class="inline-flex items-center rounded-md bg-purple-50 px-2 py-1 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10">
                  {guide.category} Strategy
                </span>
                <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10">
                  2026 Edition
                </span>
              </div>
              <h3 class="text-lg font-semibold leading-8 tracking-tight text-gray-900">{guide.title}</h3>
              <p class="mt-4 text-base leading-7 text-gray-600 line-clamp-4">
                {guide.description}
              </p>
            </div>
            <div class="mt-8 pt-6 border-t border-gray-100">
              <a href={guide.path} class="inline-flex items-center text-sm font-semibold leading-6 text-gray-900 hover:text-gray-600 transition-colors">
                Read Guide <span aria-hidden="true" class="ml-2">→</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="bg-white">
    <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8">
      <div class="relative isolate overflow-hidden bg-gray-900 px-6 py-24 text-center shadow-2xl rounded-3xl sm:px-16">
        <h2 class="mx-auto max-w-2xl text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Want to calculate your rates?
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-300">
          Put our pricing frameworks to work. Use our free interactive calculators to find your ideal hourly rates and project price points.
        </p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
          <a href="/tools" class="rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-gray-900 shadow-sm hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white transition-colors">
            Explore Calculators
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const searchInput = document.getElementById('guide-search');
  const categoryBtns = document.querySelectorAll('.category-btn');
  const guideCards = document.querySelectorAll('.guide-card');
  const noResultsMsg = document.getElementById('no-results-msg');

  let currentCategory = 'all';
  let searchQuery = '';

  function filterGuides() {
    let visibleCount = 0;

    guideCards.forEach(card => {
      const title = card.getAttribute('data-title') || '';
      const description = card.getAttribute('data-description') || '';
      const category = card.getAttribute('data-category') || '';

      const matchesSearch = title.includes(searchQuery) || description.includes(searchQuery) || category.includes(searchQuery);
      const matchesCategory = currentCategory === 'all' || category === currentCategory;

      if (matchesSearch && matchesCategory) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (visibleCount === 0) {
      noResultsMsg?.classList.remove('hidden');
    } else {
      noResultsMsg?.classList.add('hidden');
    }
  }

  // Bind search input
  searchInput?.addEventListener('input', (e) => {
    searchQuery = e.target.value.toLowerCase().trim();
    filterGuides();
  });

  // Bind category buttons
  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Toggle active styling
      categoryBtns.forEach(b => {
        b.classList.remove('bg-gray-900', 'text-white', 'border-gray-900');
        b.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
      });

      btn.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
      btn.classList.add('bg-gray-900', 'text-white', 'border-gray-900');

      currentCategory = btn.getAttribute('data-category') || 'all';
      filterGuides();
    });
  });
</script>
