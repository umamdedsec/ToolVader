---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="ToolVader - Smart Tools For Freelancers"
  description="Free tools for freelancers including freelance rate calculators, pricing tools and business utilities."
>
  <!-- Hero Section -->
  <div class="relative isolate overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 pb-12 pt-10 sm:pb-16 lg:flex lg:px-8 lg:pt-32">
      <div class="mx-auto max-w-2xl flex-shrink-0 lg:mx-0 lg:max-w-xl lg:pt-8">
        <h1 class="mt-10 text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
          Smart Tools For Freelancers
        </h1>
        <p class="mt-6 text-lg leading-8 text-gray-600">
          Calculate freelance rates, make better pricing decisions, and grow your freelance business.
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
          <a href="/tools/freelance-rate-calculator" class="rounded-md bg-gray-900 px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900 transition-colors">
            Open Freelance Rate Calculator
          </a>
          <a href="/about" class="text-center text-sm font-semibold leading-6 text-gray-900">
            Learn More <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Featured Tools Section -->
  <div class="bg-gray-50/50 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2 class="text-base font-semibold leading-7 text-gray-900">Featured Tool</h2>
      </div>
      <div class="mx-auto mt-8 max-w-2xl lg:mx-0 lg:max-w-none">
        <div class="grid grid-cols-1 gap-x-8 gap-y-16 lg:grid-cols-3">
          <!-- Freelance Rate Calculator Card -->
          <div class="flex flex-col rounded-2xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md">
            <div class="flex-1">
              <h3 class="text-lg font-semibold leading-8 tracking-tight text-gray-900">Freelance Rate Calculator</h3>
              <p class="mt-4 text-base leading-7 text-gray-600">
                Determine what you should charge clients based on profession, experience, location, and business expenses.
              </p>
            </div>
            <div class="mt-8 pt-6 border-t border-gray-100">
              <a href="/tools/freelance-rate-calculator" class="inline-flex items-center text-sm font-semibold leading-6 text-gray-900 hover:text-gray-600 transition-colors">
                Launch Calculator <span aria-hidden="true" class="ml-2">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
