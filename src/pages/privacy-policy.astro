---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Privacy Policy - ToolVader";
const description = "Learn how ToolVader handles your data and protects your privacy.";
---

<BaseLayout title={title} description={description}>
  <div class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Privacy Policy</h1>
      <p class="mt-4 text-sm text-gray-500 italic">Last updated: June 11, 2026</p>
      
      <div class="mt-10 space-y-10 text-base leading-7 text-gray-600">
        <section>
          <h2 class="text-xl font-bold text-gray-900">1. Information We Collect</h2>
          <p class="mt-4">
            ToolVader is designed to be privacy-friendly. We do not require account creation, and most of our tools, including the Freelance Rate Calculator, process data entirely on your device (client-side). 
          </p>
          <p class="mt-2">
            We may collect minimal, non-personally identifiable information such as browser type, referring pages, and time spent on the site to improve our user experience.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">2. How We Use Information</h2>
          <p class="mt-4">
            The data we collect is used solely to:
          </p>
          <ul class="mt-4 list-disc pl-5 space-y-2">
            <li>Improve the functionality and accuracy of our tools.</li>
            <li>Monitor site performance and fix technical issues.</li>
            <li>Analyze general usage trends (e.g., most popular professions).</li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">3. Cookies</h2>
          <p class="mt-4">
            We may use basic cookies or local storage to save your calculator preferences locally on your machine for your convenience. We do not use tracking cookies for advertising purposes.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">4. Third-Party Services</h2>
          <p class="mt-4">
            We may use third-party analytics services (like Google Analytics) to help us understand site traffic. These services may collect information sent by your browser.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">5. Contact</h2>
          <p class="mt-4">
            If you have any questions about this Privacy Policy, please contact us at <a href="mailto:privacy@toolvader.com" class="text-gray-900 font-medium hover:underline">privacy@toolvader.com</a>.
          </p>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
