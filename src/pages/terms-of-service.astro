---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Terms of Service - ToolVader";
const description = "The terms and conditions for using ToolVader's tools and services.";
---

<BaseLayout title={title} description={description}>
  <div class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Terms of Service</h1>
      <p class="mt-4 text-sm text-gray-500 italic">Last updated: June 11, 2026</p>
      
      <div class="mt-10 space-y-10 text-base leading-7 text-gray-600">
        <section>
          <h2 class="text-xl font-bold text-gray-900">1. Acceptance of Terms</h2>
          <p class="mt-4">
            By accessing and using ToolVader, you agree to comply with and be bound by these Terms of Service. If you do not agree to these terms, please do not use our site.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">2. Description of Service</h2>
          <p class="mt-4">
            ToolVader provides informational tools and calculators for freelancers. All results provided by our calculators are estimates and should not be considered financial, legal, or professional advice.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">3. Disclaimer of Warranties</h2>
          <p class="mt-4 italic text-gray-500 border-l-4 border-gray-100 pl-4">
            The tools and services on ToolVader are provided "as is" and "as available" without any warranty of any kind, either express or implied, including but not limited to the implied warranties of merchantability or fitness for a particular purpose.
          </p>
          <p class="mt-2">
            ToolVader does not guarantee the accuracy, completeness, or reliability of any results generated by our tools.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">4. Limitation of Liability</h2>
          <p class="mt-4">
            In no event shall ToolVader or its creators be liable for any direct, indirect, incidental, special, or consequential damages arising out of the use or inability to use our tools.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-gray-900">5. Modifications</h2>
          <p class="mt-4">
            We reserve the right to modify these terms at any time. Your continued use of the site following any changes constitutes your acceptance of the new Terms of Service.
          </p>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
