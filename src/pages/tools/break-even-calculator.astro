---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const faqData = [
  {
    question: "What is a break-even point?",
    answer: "The break-even point is the stage in a business or project where total revenues equal total expenses, resulting in zero net profit or loss. Reaching this point means your operations are self-sustaining, and any revenue generated beyond it constitutes net profit."
  },
  {
    question: "Why is break-even analysis important?",
    answer: "A break-even analysis is crucial for pricing decisions and profitability planning. It helps business owners, freelancers, and agencies determine minimum sales volumes, analyze fixed vs. variable cost structures, assess pricing feasibility, and mitigate operational risks before launching new campaigns or services."
  },
  {
    question: "How can I lower my break-even point?",
    answer: "You can lower your break-even point by either: (1) reducing your fixed overhead costs (e.g., software subscriptions, rent, insurance), (2) lowering variable costs per unit (e.g., subcontracting costs, materials, transaction fees), or (3) increasing the selling price per unit. Increasing your price raises the contribution margin, meaning you need to sell fewer units to cover costs."
  }
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Break-Even Calculator (2026)",
      "description": "Calculate break-even units and revenue instantly using ToolVader's free Break-Even Calculator.",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "All"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqData.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    }
  ]
};
---

<BaseLayout 
  title="Break-Even Calculator (2026) - ToolVader"
  description="Calculate break-even units and revenue instantly using ToolVader's free Break-Even Calculator."
  structuredData={structuredData}
>
  <div class="mx-auto max-w-4xl px-4 pt-6 pb-12 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Break-Even Calculator</h1>
      <p class="mt-4 text-lg text-gray-600">
        Calculate your break-even point in units and revenue to plan pricing and business profitability.
      </p>
    </div>

    <form id="breakeven-form" class="space-y-8 divide-y divide-gray-200 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:p-10">
      <div class="space-y-8">
        <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-3">
          <div>
            <label for="fixed-costs" class="block text-sm font-medium leading-6 text-gray-900">Total Fixed Costs ($)</label>
            <div class="mt-2">
              <input type="number" name="fixed-costs" id="fixed-costs" value="5000" min="0" step="0.01" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6" />
            </div>
            <p class="mt-2 text-xs text-gray-500">Expenses that don't change with sales volume (e.g. rent, software).</p>
          </div>

          <div>
            <label for="selling-price" class="block text-sm font-medium leading-6 text-gray-900">Selling Price Per Unit ($)</label>
            <div class="mt-2">
              <input type="number" name="selling-price" id="selling-price" value="100" min="0.01" step="0.01" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6" />
            </div>
            <p class="mt-2 text-xs text-gray-500">The amount you charge customers per unit or hour of service.</p>
          </div>

          <div>
            <label for="variable-cost" class="block text-sm font-medium leading-6 text-gray-900">Variable Cost Per Unit ($)</label>
            <div class="mt-2">
              <input type="number" name="variable-cost" id="variable-cost" value="40" min="0" step="0.01" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6" />
            </div>
            <p class="mt-2 text-xs text-gray-500">Costs directly tied to producing each unit or delivering services.</p>
          </div>
        </div>
      </div>

      <div class="pt-8">
        <button type="submit" id="calculate-btn" class="w-full rounded-md bg-gray-900 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900 transition-colors">
          Calculate Break-Even Point
        </button>
      </div>
    </form>

    <!-- Results Section -->
    <div id="results" class="mt-12 hidden space-y-10 animate-in fade-in duration-500">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="group rounded-2xl border border-blue-100 bg-blue-50/50 p-6 shadow-sm hover:border-blue-200 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-blue-700 uppercase tracking-widest">Break-Even Units</h3>
          <p class="mt-4 text-2xl font-bold text-blue-900"><span id="res-units">0</span></p>
          <p class="mt-2 text-[10px] font-extrabold text-blue-400 uppercase tracking-widest">UNITS NEEDED</p>
        </div>
        <div class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:border-gray-300 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Break-Even Revenue</h3>
          <p class="mt-4 text-2xl font-bold text-gray-900">$<span id="res-revenue">0.00</span></p>
          <p class="mt-2 text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">MINIMUM REVENUE</p>
        </div>
        <div class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:border-gray-300 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Fixed Costs</h3>
          <p class="mt-4 text-2xl font-bold text-gray-900">$<span id="res-fixed">0.00</span></p>
          <p class="mt-2 text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">TOTAL OVERHEAD</p>
        </div>
        <div class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:border-gray-300 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Contribution Margin</h3>
          <p class="mt-4 text-2xl font-bold text-gray-900">$<span id="res-margin">0.00</span></p>
          <p class="mt-2 text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">PER UNIT ($)</p>
        </div>
      </div>

      <div class="flex justify-center">
        <button id="copy-btn" class="inline-flex items-center gap-2 rounded-xl bg-gray-900 px-6 py-3 text-sm font-semibold text-white hover:bg-gray-700 transition-all active:scale-95">
          <span>Copy Results</span>
        </button>
      </div>
    </div>

    <!-- SEO Content Section -->
    <div class="mt-24 border-t border-gray-100 pt-16">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Understanding Break-Even Analysis for Modern Businesses</h2>
      <div class="mt-6 space-y-6 text-base leading-7 text-gray-600">
        <p>
          In the business landscape of 2026, launching any venture—whether you are working in <strong>freelancing</strong>, operating digital <strong>agencies</strong>, managing solo consulting firms, or building physical <strong>product businesses</strong>—requires a detailed grasp of your financial baseline. Performing a <strong>break-even analysis</strong> is the most critical first step for verifying feasibility, setting pricing structures, and establishing long-term <strong>profitability planning</strong>. It answers the fundamental question: <em>Exactly how much do I need to sell to avoid losing money?</em>
        </p>
        <p>
          For independent consultants and freelancers, break-even calculations are heavily tied to billable capacity. In this context, "fixed costs" represent your monthly business expenses (such as software subscriptions, professional insurance, web hosting, and tax savings placeholders) plus your target personal take-home pay. The "selling price per unit" is your hourly rate, and the "variable cost per unit" accounts for client-specific expenses like subcontractor pay or platform transaction fees.
        </p>
        <p>
          For physical product businesses and agencies, the calculation helps guide critical <strong>pricing decisions</strong>. If your break-even units volume exceeds your operational capacity, it indicates that your price point is either too low or your variable cost structure is too high. By simulating price increases or cost cuts in the <strong>Break-Even Calculator</strong>, you can instantly observe the impact on your operational thresholds and adjust margins accordingly to build a highly sustainable business.
        </p>
        <p>
          Ultimately, data-driven planning overrides gut feelings. Knowing your numbers gives you a competitive advantage, enabling you to negotiate contracts, pitch to investors, and expand service offerings with the confidence of an experienced operator. Use ToolVader to calculate your margins, assess risks, and navigate your business toward steady profitability in 2026.
        </p>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="mt-24 border-t border-gray-100 pt-16">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Frequently Asked Questions</h2>
      <dl class="mt-10 space-y-8">
        {faqData.map(item => (
          <div>
            <dt class="text-base font-semibold leading-7 text-gray-900">{item.question}</dt>
            <dd class="mt-2 text-base leading-7 text-gray-600">{item.answer}</dd>
          </div>
        ))}
      </dl>
    </div>

    <RelatedTools currentPath="/tools/break-even-calculator" />
  </div>
</BaseLayout>

<script is:inline>
  const form = document.getElementById('breakeven-form');
  const resultsDiv = document.getElementById('results');
  const resUnits = document.getElementById('res-units');
  const resRevenue = document.getElementById('res-revenue');
  const resFixed = document.getElementById('res-fixed');
  const resMargin = document.getElementById('res-margin');
  const copyBtn = document.getElementById('copy-btn');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const fixedCosts = Number(formData.get('fixed-costs'));
    const sellingPrice = Number(formData.get('selling-price'));
    const variableCost = Number(formData.get('variable-cost'));

    if (fixedCosts < 0 || sellingPrice < 0 || variableCost < 0) {
      alert('Values cannot be negative.');
      return;
    }

    if (sellingPrice <= variableCost) {
      alert('Selling Price must be greater than Variable Cost.');
      return;
    }

    const contributionMargin = sellingPrice - variableCost;
    const breakEvenUnits = fixedCosts / contributionMargin;
    const breakEvenRevenue = breakEvenUnits * sellingPrice;

    if (resUnits) resUnits.textContent = breakEvenUnits.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 });
    if (resRevenue) resRevenue.textContent = breakEvenRevenue.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (resFixed) resFixed.textContent = fixedCosts.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (resMargin) resMargin.textContent = contributionMargin.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    resultsDiv?.classList.remove('hidden');
    resultsDiv?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  copyBtn?.addEventListener('click', () => {
    const text = `Break-Even Calculation Results:
Fixed Costs: $${resFixed?.textContent}
Contribution Margin (Per Unit): $${resMargin?.textContent}
Break-Even Units: ${resUnits?.textContent} Units
Break-Even Revenue: $${resRevenue?.textContent}

Calculated by ToolVader`;

    navigator.clipboard.writeText(text).then(() => {
      const span = copyBtn.querySelector('span');
      if (span) {
        const originalText = span.textContent;
        span.textContent = 'Copied!';
        setTimeout(() => {
          span.textContent = originalText;
        }, 2000);
      }
    });
  });
</script>
