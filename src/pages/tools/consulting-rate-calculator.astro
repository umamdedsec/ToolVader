---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const faqData = [
  {
    question: "What is the difference between consulting and freelancing?",
    answer: "Freelancing is primarily execution-oriented, where you are hired to deliver specific outputs or tasks (e.g., writing code, designing logos, writing blogs). Consulting is strategic and diagnostic; you are hired for your expertise, analysis, and advice to solve specific business problems (e.g., advising on growth strategies, optimizing workflows, auditing security protocols)."
  },
  {
    question: "How do consultants determine their hourly rates?",
    answer: "Consultants calculate hourly rates by adding target salary requirements to operating business overhead and self-employment tax placeholders, then dividing this total target revenue by expected annual billable hours. A multiplier is often applied to this base rate to reflect the consultant's level of expertise, experience, and industry demand."
  },
  {
    question: "What is a typical billable utilization rate for consultants?",
    answer: "A typical billable utilization rate ranges between 45% and 60%. Because consultants spend a significant amount of time on business development, pitching proposals, writing contracts, administrative bookkeeping, and industry research, they cannot bill clients for a full 40-hour week. Expecting 20 to 24 billable hours weekly is standard."
  },
  {
    question: "When should consultants use project pricing instead of hourly billing?",
    answer: "Project-based or fixed-pricing should be used when the project scope, deliverables, and milestones are clearly defined. Project pricing protects your margins, rewards efficiency, and provides upfront price certainty for the client. If you complete a fixed-price project quickly due to your expertise, your effective hourly rate increases."
  },
  {
    question: "What is value-based pricing in consulting?",
    answer: "Value-based pricing is a premium quoting strategy where fees are set based on the estimated financial impact or business outcomes the client will receive, rather than hours worked or cost of delivery. If your strategy will save a client $200,000 in operating costs, a flat consulting fee of $30,000 is highly reasonable, even if the work takes only 15 hours."
  }
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Consulting Rate Calculator 2026",
      "description": "Calculate consulting rates based on experience, expenses, utilization and target income. Free consultant pricing calculator for 2026.",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "All"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqData.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    }
  ]
};
---

<BaseLayout 
  title="Consulting Rate Calculator 2026 - Calculate Your Consulting Fees"
  description="Calculate consulting rates based on experience, expenses, utilization and target income. Free consultant pricing calculator for 2026."
  structuredData={structuredData}
>
  <div class="mx-auto max-w-4xl px-4 pt-6 pb-12 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Consulting Rate Calculator</h1>
      <p class="mt-4 text-lg text-gray-600">
        Calculate your professional hourly rate, monthly revenue targets, and annual targets based on experience, overhead, and billable utilization.
      </p>
    </div>

    <form id="consulting-form" class="space-y-8 divide-y divide-gray-200 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:p-10">
      <div class="space-y-8">
        <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
          
          <div>
            <label for="target-income" class="block text-sm font-medium leading-6 text-gray-900">Target Annual Income ($)</label>
            <div class="mt-2">
              <input type="number" name="target-income" id="target-income" value="100000" min="0" step="1000" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6" />
            </div>
            <p class="mt-2 text-xs text-gray-500">Your desired take-home salary before taxes and business overhead.</p>
          </div>

          <div>
            <label for="expenses" class="block text-sm font-medium leading-6 text-gray-900">Annual Business Expenses ($)</label>
            <div class="mt-2">
              <input type="number" name="expenses" id="expenses" value="15000" min="0" step="500" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6" />
            </div>
            <p class="mt-2 text-xs text-gray-500">Your total operating costs (e.g. software, office, travel, legal, CPA fees).</p>
          </div>

          <div>
            <label for="hours" class="block text-sm font-medium leading-6 text-gray-900">Target Weekly Hours</label>
            <div class="mt-2">
              <input type="number" name="hours" id="hours" value="40" min="1" max="168" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6" />
            </div>
            <p class="mt-2 text-xs text-gray-500">Total number of hours you wish to devote to your business weekly.</p>
          </div>

          <div>
            <label for="utilization" class="block text-sm font-medium leading-6 text-gray-900">Billable Utilization (%)</label>
            <div class="mt-2">
              <input type="number" name="utilization" id="utilization" value="50" min="0" max="100" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6" />
            </div>
            <p class="mt-2 text-xs text-gray-500">Percentage of working hours actually billed to clients vs admin work.</p>
          </div>

          <div class="sm:col-span-2 lg:col-span-1">
            <label for="experience" class="block text-sm font-medium leading-6 text-gray-900">Experience & Expertise</label>
            <div class="mt-2">
              <select name="experience" id="experience" class="block w-full rounded-md border-0 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6">
                <option value="beginner">Beginner (1.0x)</option>
                <option value="intermediate">Intermediate (1.15x)</option>
                <option value="senior" selected>Senior (1.35x)</option>
                <option value="expert">Expert / Authority (1.6x)</option>
              </select>
            </div>
            <p class="mt-2 text-xs text-gray-500">Your expertise level, adding premium multiplier weights to rates.</p>
          </div>

        </div>
      </div>

      <div class="pt-8">
        <button type="submit" id="calculate-btn" class="w-full rounded-md bg-gray-900 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900 transition-colors">
          Calculate Consulting Rates
        </button>
      </div>
    </form>

    <!-- Results Section -->
    <div id="results" class="mt-12 hidden space-y-10 animate-in fade-in duration-500">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        
        <div class="group rounded-2xl border border-blue-100 bg-blue-50/50 p-6 shadow-sm hover:border-blue-200 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-blue-700 uppercase tracking-widest">Hourly Rate</h3>
          <p class="mt-4 text-2xl font-bold text-blue-900">$<span id="res-rate">0.00</span></p>
          <p class="mt-2 text-[10px] font-extrabold text-blue-400 uppercase tracking-widest">RECOMMENDED RATE</p>
        </div>

        <div class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:border-gray-300 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Monthly Target</h3>
          <p class="mt-4 text-2xl font-bold text-gray-900">$<span id="res-monthly">0.00</span></p>
          <p class="mt-2 text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">REQUIRED REVENUE</p>
        </div>

        <div class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:border-gray-300 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Annual Revenue</h3>
          <p class="mt-4 text-2xl font-bold text-gray-900">$<span id="res-annual">0.00</span></p>
          <p class="mt-2 text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">TARGET WITH PREMIUM</p>
        </div>

        <div class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:border-gray-300 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Utilization</h3>
          <p class="mt-4 text-2xl font-bold text-gray-900"><span id="res-utilization">0</span>%</p>
          <p class="mt-2 text-[10px] font-extrabold text-gray-400 uppercase tracking-widest">EFFECTIVE BILLABLE</p>
        </div>

      </div>

      <div class="flex justify-center">
        <button id="copy-btn" class="inline-flex items-center gap-2 rounded-xl bg-gray-900 px-6 py-3 text-sm font-semibold text-white hover:bg-gray-700 transition-all active:scale-95">
          <span>Copy Results</span>
        </button>
      </div>
    </div>

    <!-- SEO Content Section -->
    <div class="mt-24 border-t border-gray-100 pt-16">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Understanding Consultant Pricing Models and Rate Setting</h2>
      <div class="mt-6 space-y-6 text-base leading-7 text-gray-600">
        <p>
          Establishing a sustainable and profitable pricing structure is the single most important task for an independent consultant in 2026. Unlike salaried professionals, consultants must cover their own overhead, self-employment taxes, health insurance benefits, and administrative downtime out of their billing rates. A common mistake for new consultants is translating their previous corporate salary directly into an hourly rate, which fails to account for the overhead of running a solo advisory business.
        </p>
        <p>
          Consultant pricing is fundamentally grounded in billable capacity. Since a significant portion of your week is spent on business development, pitching proposals, and administrative work, you cannot expect a 100% utilization rate. Standard utilization ranges between 45% and 60%, meaning you only bill for 18 to 24 hours in a typical 40-hour workweek. Your hourly rate must be scaled to support this structural downtime. By dividing your target annual revenue (desired salary plus expenses) by your actual billable hours and adding an experience multiplier, you protect your cash flow and ensure profit margins.
        </p>
        
        <h3 class="text-lg font-semibold text-gray-900 mt-8">The Difference Between Freelancing and Consulting</h3>
        <p>
          While the terms are often used interchangeably, freelancing and consulting represent distinct models on the service delivery spectrum. Freelancing is execution-focused; you are hired to deliver a physical or digital product, such as writing code, designing layouts, or writing copywriting copy. The client tells you what they need, and you build it. Freelance pricing is heavily commoditized and closely tied to hours spent.
        </p>
        <p>
          Consulting, conversely, is strategic, analytical, and diagnostic. Consultants are hired to identify business bottlenecks, audit protocols, and advise executives on decision-making. As a consultant, you tell the client *what* to build or *how* to solve a problem. Because you operate higher on the business value chain, you are valued for your expertise and strategic impact rather than raw labor. This distinction enables consultants to charge premium multipliers and move away from commodity pricing.
        </p>

        <h3 class="text-lg font-semibold text-gray-900 mt-8">Transitioning to Value-Based Pricing</h3>
        <p>
          The ultimate goal for any seasoned consultant is value-based pricing. This model decouples your income from your time entirely, setting project fees based on the estimated financial outcome or return on investment the client receives. If your advisory services help a client increase sales conversions by 3%, resulting in an extra $300,000 in revenue, charging a $30,000 flat consulting fee is highly profitable for them, even if the analysis and presentation take only 15 hours of your actual time.
        </p>
        <p>
          To implement value-based pricing, you must master the discovery call, uncover the client's true business value, and demonstrate a clear ROI. By framing your fees in relation to the financial impact you deliver, you eliminate hourly rate caps and build a highly scalable consulting business in 2026.
        </p>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="mt-24 border-t border-gray-100 pt-16">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Frequently Asked Questions</h2>
      <dl class="mt-10 space-y-8">
        {faqData.map(item => (
          <div>
            <dt class="text-base font-semibold leading-7 text-gray-900">{item.question}</dt>
            <dd class="mt-2 text-base leading-7 text-gray-600">{item.answer}</dd>
          </div>
        ))}
      </dl>
    </div>

    <RelatedTools currentPath="/tools/consulting-rate-calculator" />
  </div>
</BaseLayout>

<script is:inline>
  const form = document.getElementById('consulting-form');
  const resultsDiv = document.getElementById('results');
  const resRate = document.getElementById('res-rate');
  const resMonthly = document.getElementById('res-monthly');
  const resAnnual = document.getElementById('res-annual');
  const resUtilization = document.getElementById('res-utilization');
  const copyBtn = document.getElementById('copy-btn');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const targetIncome = Number(formData.get('target-income'));
    const expenses = Number(formData.get('expenses'));
    const hours = Number(formData.get('hours'));
    const utilization = Number(formData.get('utilization'));
    const experience = formData.get('experience');

    if (targetIncome < 0 || expenses < 0 || hours < 0 || utilization < 0) {
      alert('Values cannot be negative.');
      return;
    }

    if (utilization < 0 || utilization > 100) {
      alert('Utilization percentage must be between 0 and 100.');
      return;
    }

    if (hours <= 0 || hours > 168) {
      alert('Weekly hours must be between 1 and 168.');
      return;
    }

    let multiplier = 1.0;
    if (experience === 'intermediate') multiplier = 1.15;
    else if (experience === 'senior') multiplier = 1.35;
    else if (experience === 'expert') multiplier = 1.6;

    const annualBillableHours = (hours * 52) * (utilization / 100);
    const annualRevenueTarget = (targetIncome + expenses) * multiplier;
    const hourlyRate = annualBillableHours > 0 ? annualRevenueTarget / annualBillableHours : 0;
    const monthlyRevenueTarget = annualRevenueTarget / 12;

    if (resRate) resRate.textContent = hourlyRate.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (resMonthly) resMonthly.textContent = monthlyRevenueTarget.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (resAnnual) resAnnual.textContent = annualRevenueTarget.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (resUtilization) resUtilization.textContent = utilization.toString();

    resultsDiv?.classList.remove('hidden');
    resultsDiv?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  copyBtn?.addEventListener('click', () => {
    const experienceSelect = document.getElementById('experience');
    const selectedExpText = experienceSelect?.options[experienceSelect.selectedIndex].text;

    const text = `Consulting Rate Estimation:
Desired Annual Income: $${Number(document.getElementById('target-income').value).toLocaleString(undefined, { minimumFractionDigits: 2 })}
Business Expenses: $${Number(document.getElementById('expenses').value).toLocaleString(undefined, { minimumFractionDigits: 2 })}
Weekly Hours: ${document.getElementById('hours').value} Hours
Billable Percentage: ${document.getElementById('utilization').value}%
Experience Level: ${selectedExpText}

Recommended Hourly Rate: $${resRate?.textContent}
Monthly Revenue Target: $${resMonthly?.textContent}
Annual Revenue Target: $${resAnnual?.textContent}
Effective Utilization: ${resUtilization?.textContent}%

Calculated by ToolVader`;

    navigator.clipboard.writeText(text).then(() => {
      const span = copyBtn.querySelector('span');
      if (span) {
        const originalText = span.textContent;
        span.textContent = 'Copied!';
        setTimeout(() => {
          span.textContent = originalText;
        }, 2000);
      }
    });
  });
</script>
