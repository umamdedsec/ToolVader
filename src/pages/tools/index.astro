---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tools } from '../../data/tools';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Free Business Calculators & Tools - ToolVader",
  "description": "Browse all free business calculators and tools from ToolVader for freelancers, consultants, remote workers and solopreneurs.",
  "url": "https://toolvader.com/tools"
};
---

<BaseLayout 
  title="Free Business Calculators & Tools - ToolVader"
  description="Browse all free business calculators and tools from ToolVader for freelancers, consultants, remote workers and solopreneurs."
  structuredData={structuredData}
>
  <!-- Hero Section -->
  <div class="bg-white px-6 py-16 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">Free Business Calculators for Freelancers & Professionals</h1>
      <p class="mt-6 text-lg leading-8 text-gray-600">
        Free business calculators designed to help freelancers, consultants and independent professionals make better financial decisions.
      </p>
    </div>
  </div>

  <!-- Tool Grid Section -->
  <div class="bg-gray-50/50 py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        {tools.map((tool) => (
          <div class="flex flex-col rounded-2xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md">
            <div class="flex-1">
              <div class="flex items-center gap-x-3 mb-6">
                <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                  {tool.category}
                </span>
                <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10">
                  Updated for 2026
                </span>
              </div>
              <h3 class="text-lg font-semibold leading-8 tracking-tight text-gray-900">{tool.title}</h3>
              <p class="mt-4 text-base leading-7 text-gray-600">
                {tool.description}
              </p>
            </div>
            <div class="mt-8 pt-6 border-t border-gray-100">
              <a href={tool.href} class="inline-flex items-center text-sm font-semibold leading-6 text-gray-900 hover:text-gray-600 transition-colors">
                Launch Calculator <span aria-hidden="true" class="ml-2">→</span>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="bg-white">
    <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8">
      <div class="relative isolate overflow-hidden bg-gray-900 px-6 py-24 text-center shadow-2xl rounded-3xl sm:px-16">
        <h2 class="mx-auto max-w-2xl text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Need a tool we don't have yet?
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-300">
          We're constantly building new utilities for the independent workforce. Let us know what you need.
        </p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
          <a href="/contact" class="rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-gray-900 shadow-sm hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white transition-colors">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
