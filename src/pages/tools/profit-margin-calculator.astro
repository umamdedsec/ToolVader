---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const faqData = [
  {
    question: "What is profit margin?",
    answer: "Profit margin is a financial metric used to assess the profitability of a business or project. It represents the percentage of revenue that exceeds the costs of doing business. A higher margin indicates a more profitable and sustainable operation."
  },
  {
    question: "What is a good profit margin?",
    answer: "A 'good' profit margin varies by industry. For service-based freelancers and agencies, a net profit margin of 20-40% is often considered healthy. In ecommerce, margins might be lower (10-20%) due to physical inventory and shipping costs. Ultimately, a good margin is one that allows for both business growth and a sustainable personal income."
  },
  {
    question: "What is the difference between markup and margin?",
    answer: "While both relate to profit, they use different denominators. Margin is profit divided by revenue (selling price), while markup is profit divided by cost. For example, if you buy something for $50 and sell it for $100, your markup is 100%, but your profit margin is 50%."
  }
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Profit Margin Calculator (2026)",
      "description": "Calculate profit margin, markup, revenue and net profit instantly with ToolVader's free Profit Margin Calculator.",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "All"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqData.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    }
  ]
};
---

<BaseLayout 
  title="Profit Margin Calculator (2026) - ToolVader"
  description="Calculate profit margin, markup, revenue and net profit instantly with ToolVader's free Profit Margin Calculator."
  structuredData={structuredData}
>
  <div class="mx-auto max-w-4xl px-4 pt-6 pb-12 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Profit Margin Calculator</h1>
      <p class="mt-4 text-lg text-gray-600">
        Calculate your business profit margin, revenue and markup in seconds.
      </p>
    </div>

    <form id="margin-form" class="space-y-8 divide-y divide-gray-200 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:p-10">
      <div class="space-y-8">
        <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-2">
          <div>
            <label for="revenue" class="block text-sm font-medium leading-6 text-gray-900">Total Revenue ($)</label>
            <div class="mt-2">
              <input type="number" name="revenue" id="revenue" value="1000" min="0" step="0.01" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6" />
            </div>
          </div>

          <div>
            <label for="cost" class="block text-sm font-medium leading-6 text-gray-900">Total Cost ($)</label>
            <div class="mt-2">
              <input type="number" name="cost" id="cost" value="600" min="0" step="0.01" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6" />
            </div>
          </div>
        </div>
      </div>

      <div class="pt-8">
        <button type="submit" id="calculate-btn" class="w-full rounded-md bg-gray-900 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900 transition-colors">
          Calculate Margins
        </button>
      </div>
    </form>

    <!-- Results Section -->
    <div id="results" class="mt-12 hidden space-y-10 animate-in fade-in duration-500">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:border-gray-300 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Net Profit</h3>
          <p class="mt-4 text-2xl font-bold text-gray-900">$<span id="res-profit">0.00</span></p>
        </div>
        <div class="group rounded-2xl border border-blue-100 bg-blue-50/50 p-6 shadow-sm hover:border-blue-200 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-blue-700 uppercase tracking-widest">Profit Margin</h3>
          <p class="mt-4 text-2xl font-bold text-blue-900"><span id="res-margin">0.00</span>%</p>
        </div>
        <div class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:border-gray-300 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Markup</h3>
          <p class="mt-4 text-2xl font-bold text-gray-900"><span id="res-markup">0.00</span>%</p>
        </div>
        <div class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm hover:border-gray-300 hover:shadow-md transition-all text-center">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest">Revenue</h3>
          <p class="mt-4 text-2xl font-bold text-gray-900">$<span id="res-revenue">0.00</span></p>
        </div>
      </div>

      <div class="flex justify-center">
        <button id="copy-btn" class="inline-flex items-center gap-2 rounded-xl bg-gray-900 px-6 py-3 text-sm font-semibold text-white hover:bg-gray-700 transition-all active:scale-95">
          <span>Copy Results</span>
        </button>
      </div>
    </div>

    <!-- SEO Content Section -->
    <div class="mt-24 border-t border-gray-100 pt-16">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Why Profit Margin Matters</h2>
      <div class="mt-6 space-y-6 text-base leading-7 text-gray-600">
        <p>
          In the competitive landscape of 2026, understanding your <strong>profit margin</strong> is not just for large corporations—it is a vital skill for every <strong>freelancer, agency owner, and ecommerce entrepreneur</strong>. A profit margin tells you how much money your business actually keeps after paying all expenses. Without this clarity, you might be generating high revenue while technically losing money.
        </p>
        <p>
          For <strong>agencies and consultants</strong>, tracking margins on a per-project basis allows for better <strong>business growth</strong> and scaling. It helps you identify which services are your "profit engines" and which are "resource drains." By focusing on high-margin offerings, you can increase your take-home pay without necessarily increasing your workload.
        </p>
        <p>
          In <strong>ecommerce</strong>, where shipping, marketing, and inventory costs are constantly shifting, the <strong>Profit Margin Calculator</strong> becomes an essential daily tool. It enables you to make informed <strong>pricing decisions</strong> that protect your bottom line against rising overheads. Knowing your <strong>markup</strong> is also crucial for competitive analysis, ensuring your products are priced high enough to cover costs but low enough to remain attractive to customers.
        </p>
        <p>
          Ultimately, professional financial management is about data, not guesswork. By regularly analyzing your margins, you can ensure your independent career or small business remains sustainable and profitable for years to come. Use ToolVader to stay ahead of the curve and manage your finances with the precision of a seasoned CFO.
        </p>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="mt-24 border-t border-gray-100 pt-16">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Frequently Asked Questions</h2>
      <dl class="mt-10 space-y-8">
        {faqData.map(item => (
          <div>
            <dt class="text-base font-semibold leading-7 text-gray-900">{item.question}</dt>
            <dd class="mt-2 text-base leading-7 text-gray-600">{item.answer}</dd>
          </div>
        ))}
      </dl>
    </div>

    <RelatedTools currentPath="/tools/profit-margin-calculator" />
  </div>
</BaseLayout>

<script is:inline>
  const form = document.getElementById('margin-form');
  const resultsDiv = document.getElementById('results');
  const resProfit = document.getElementById('res-profit');
  const resMargin = document.getElementById('res-margin');
  const resMarkup = document.getElementById('res-markup');
  const resRevenue = document.getElementById('res-revenue');
  const copyBtn = document.getElementById('copy-btn');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const revenue = Number(formData.get('revenue'));
    const cost = Number(formData.get('cost'));

    if (cost > revenue) {
      alert('Cost cannot exceed Revenue. Please check your numbers.');
      return;
    }

    if (revenue < 0 || cost < 0) {
      alert('Values cannot be negative.');
      return;
    }

    const profit = revenue - cost;
    const margin = revenue > 0 ? (profit / revenue) * 100 : 0;
    const markup = cost > 0 ? (profit / cost) * 100 : 0;

    if (resProfit) resProfit.textContent = profit.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (resMargin) resMargin.textContent = margin.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (resMarkup) resMarkup.textContent = markup.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (resRevenue) resRevenue.textContent = revenue.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    resultsDiv?.classList.remove('hidden');
    resultsDiv?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  copyBtn?.addEventListener('click', () => {
    const text = `Profit Margin Calculation:
Revenue: $${resRevenue?.textContent}
Cost: $${(Number(resRevenue?.textContent?.replace(/,/g, '')) - Number(resProfit?.textContent?.replace(/,/g, ''))).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
Net Profit: $${resProfit?.textContent}
Profit Margin: ${resMargin?.textContent}%
Markup: ${resMarkup?.textContent}%

Calculated by ToolVader`;

    navigator.clipboard.writeText(text).then(() => {
      const span = copyBtn.querySelector('span');
      if (span) {
        const originalText = span.textContent;
        span.textContent = 'Copied!';
        setTimeout(() => {
          span.textContent = originalText;
        }, 2000);
      }
    });
  });
</script>
